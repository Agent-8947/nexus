{
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "e:/Downloads/--ANTIGRAVITY store/IDE-optimus/PROJECT"
            ]
        },
        "git": {
            "command": "uvx",
            "args": [
                "mcp-server-git",
                "--repository",
                "e:/Downloads/--ANTIGRAVITY store/IDE-optimus/PROJECT"
            ]
        },
        "memory": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-memory"
            ]
        },
        "sqlite": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sqlite",
                "--db",
                "e:/Downloads/--ANTIGRAVITY store/IDE-optimus/PROJECT/nexus_optimus.db"
            ]
        },
        "fetch": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-fetch"
            ]
        },
        "brave-search": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-brave-search"
            ],
            "env": {
                "BRAVE_API_KEY": ""
            }
        },
        "sentry": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sentry"
            ],
            "env": {
                "SENTRY_AUTH_TOKEN": "",
                "SENTRY_ORG": ""
            }
        },
        "puppeteer": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-puppeteer"
            ]
        },
        "sequentialthinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequentialthinking"
            ]
        },
        "everart": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-everart"
            ],
            "env": {
                "EVERART_API_KEY": ""
            }
        },
        "obsidian": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-server-obsidian",
                "--vault",
                "e:/Downloads/--ANTIGRAVITY store/IDE-optimus/PROJECT/OBSIDIAN_VAULT"
            ]
        },
        "contentful": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-contentful"
            ],
            "env": {
                "CONTENTFUL_SPACE_ID": "",
                "CONTENTFUL_ACCESS_TOKEN": ""
            }
        },
        "osp-marketing": {
            "command": "npx",
            "args": [
                "-y",
                "osp-marketing-mcp-tools"
            ]
        },
        "ai-therapist": {
            "command": "npx",
            "args": [
                "-y",
                "@danieldunderfelt/ai-therapist-mcp"
            ]
        }
    }
}