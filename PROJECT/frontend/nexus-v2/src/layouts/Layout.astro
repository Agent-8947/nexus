---
import "../styles/global.css";
const { title = "NEXUS OS | Neural Architect" } = Astro.props;
import Scene from "../components/ThreeD/Scene.svelte";
---

<!doctype html>
<html lang="en" class="scroll-smooth bg-black">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Plus+Jakarta+Sans:wght@400;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="antialiased selection:bg-[#00f3ff]/30 overflow-x-hidden min-h-screen bg-black text-white"
	>
		<div
			id="progress-bar"
			class="fixed top-0 left-0 h-1 bg-gradient-to-r from-[#00f3ff] to-blue-600 z-[100] w-0 transition-all duration-150 shadow-[0_0_10px_rgba(0,243,255,0.5)]"
		>
		</div>

		<!-- PERMANENT 3D BACKGROUND LAYER -->
		<div
			class="fixed inset-0 z-0 pointer-events-none opacity-60 overflow-hidden"
		>
			<Scene client:only="svelte" />
		</div>

		<div class="aurora-bg z-[1]"></div>

		<div class="relative z-10 w-full min-h-screen">
			<slot />
		</div>

		<script is:inline>
			window.addEventListener("scroll", () => {
				const winScroll =
					document.body.scrollTop ||
					document.documentElement.scrollTop;
				const height =
					document.documentElement.scrollHeight -
					document.documentElement.clientHeight;
				const scrolled = (winScroll / height) * 100;
				const pb = document.getElementById("progress-bar");
				if (pb) pb.style.width = scrolled + "%";
			});
		</script>
	</body>
</html>
